# HarmonyAI — переменные окружения (Vercel)
# Скопируйте нужные значения в Vercel → Settings → Environment Variables.
# Этот файл — только образец; реальные ключи сюда не вписывать и не коммитить.

# === ИИ-провайдер чата (Codex API, OpenAI-совместимый) ===
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.codex-api.online/v1

# === Модели чата (Adanatos = free, Dynatos = pro) ===
# Реальные имена моделей за брендами можно поменять здесь без правки кода.
ADANATOS_MODEL=gpt-5.4
ADANATOS_FALLBACK=gpt-5.4
DYNATOS_MODEL=gpt-5.5
DYNATOS_FALLBACK=gpt-5.4

# === Supabase (база, авторизация, Storage) ===
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Для генерации изображений нужно создать public bucket "generated-images"
# в Supabase → Storage → New bucket (Public = on).

# === Зарезервировано (не используется в текущей маршрутизации) ===
GEMINI_API_KEY=

# === ЮKassa (платежи) ===
YOOKASSA_SHOP_ID=1411296
YOOKASSA_SECRET_KEY=
# URL сайта — используется как return_url после оплаты
SITE_URL=https://harmonyai-zeta.vercel.app


# Account ID: Cloudflare dashboard → справа внизу на любой странице.
# API Token: My Profile → API Tokens → Create Token → Permissions:
#   Account → Workers AI → Edit.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell
